<Window x:Class="AiReportDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="可研报告智能审查助手"
        Width="1360"
        Height="860"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F8"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="TextBrush" Color="#101828"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#667085"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PageBrush" Color="#EEF2F8"/>
        <SolidColorBrush x:Key="DarkBrush" Color="#101828"/>
        <SolidColorBrush x:Key="DarkSoftBrush" Color="#1D2939"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D8DEE9"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
        </Style>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DarkSoftBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActiveNavButton" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,11"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="PasswordInput" TargetType="PasswordBox">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,11"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>

        <Style x:Key="SegmentRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#F2F4F7"/>
            <Setter Property="BorderBrush" Value="#D0D5DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="LoginPage">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource DarkBrush}">
                <StackPanel Margin="58,70,58,48">
                    <TextBlock Text="可研报告" Foreground="White" FontSize="36" FontWeight="Bold"/>
                    <TextBlock Text="智能审查助手" Foreground="White" FontSize="36" FontWeight="Bold" Margin="0,4,0,0"/>
                    <TextBlock Text="Windows 桌面客户端" Foreground="#CBD5E1" FontSize="15" Margin="0,18,0,42"/>

                    <Border Background="{StaticResource DarkSoftBrush}" CornerRadius="12" Padding="18" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="九项审查统一入口" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="围绕依据、重复建设、功能对应、数据填报、资源申请、安全内容、价格、询价和信创要求进行选择。"
                                       Foreground="#D0D5DD" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource DarkSoftBrush}" CornerRadius="12" Padding="18" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="本地报告工作台" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="先完成报告选择和任务创建，后续接入解析、模型审查和结果导出。"
                                       Foreground="#D0D5DD" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource DarkSoftBrush}" CornerRadius="12" Padding="18">
                        <StackPanel>
                            <TextBlock Text="桌面软件交付形态" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="不再要求用户打开浏览器，后续可打包为 Windows 可执行程序或安装包。"
                                       Foreground="#D0D5DD" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Background="{StaticResource PageBrush}">
                <Border Style="{StaticResource CardBorder}" Width="520" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="36,34">
                    <StackPanel>
                        <TextBlock Text="账号入口" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="当前阶段不连接数据库，登录或注册后直接进入工作台。"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,8,0,24" TextWrapping="Wrap"/>

                        <Grid Margin="0,0,0,22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <RadioButton x:Name="LoginModeButton" Content="登录" Style="{StaticResource SegmentRadio}" IsChecked="True" Checked="OnLoginModeChanged" Margin="0,0,8,0"/>
                            <RadioButton x:Name="RegisterModeButton" Grid.Column="1" Content="注册" Style="{StaticResource SegmentRadio}" Checked="OnLoginModeChanged"/>
                        </Grid>

                        <TextBlock Text="账号" Foreground="#344054" Margin="0,0,0,7"/>
                        <TextBox x:Name="AccountTextBox" Style="{StaticResource InputBox}" Margin="0,0,0,14"/>

                        <TextBlock Text="密码" Foreground="#344054" Margin="0,0,0,7"/>
                        <PasswordBox x:Name="PasswordBox" Style="{StaticResource PasswordInput}" Margin="0,0,0,14"/>

                        <StackPanel x:Name="RegisterFields" Visibility="Collapsed">
                            <TextBlock Text="确认密码" Foreground="#344054" Margin="0,0,0,7"/>
                            <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource PasswordInput}" Margin="0,0,0,14"/>

                            <TextBlock Text="单位名称" Foreground="#344054" Margin="0,0,0,7"/>
                            <TextBox x:Name="OrganizationTextBox" Style="{StaticResource InputBox}" Margin="0,0,0,14"/>
                        </StackPanel>

                        <Button x:Name="EnterButton" Content="登录并进入系统" Style="{StaticResource PrimaryButton}" Click="OnEnterClicked"/>
                        <TextBlock Text="后续可接入真实账号体系、权限控制和审查记录。"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,18,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="WorkbenchPage" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Border Background="{StaticResource DarkBrush}">
                <DockPanel Margin="22,26,22,22">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="AI 审查助手" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock x:Name="UserTextBlock" Text="当前用户：演示用户" Foreground="#D0D5DD" Margin="0,8,0,28"/>

                        <Button Content="可研报告检测" Style="{StaticResource ActiveNavButton}" Margin="0,0,0,8"/>
                        <Button Content="审查记录" Style="{StaticResource NavButton}" Margin="0,0,0,8"/>
                        <Button Content="知识库配置" Style="{StaticResource NavButton}" Margin="0,0,0,8"/>
                        <Button Content="系统设置" Style="{StaticResource NavButton}"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom">
                        <TextBlock Text="桌面前端页面完成版" Foreground="#D0D5DD" Margin="0,0,0,4"/>
                        <TextBlock Text="后续接入后端检测服务" Foreground="#98A2B3" Margin="0,0,0,18"/>
                        <Button Content="退出登录" Style="{StaticResource SecondaryButton}" Click="OnLogoutClicked"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1" Margin="28,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <StackPanel>
                        <TextBlock Text="可研报告智能检测工作台" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="上传报告后，选择需要 AI 助手检测的审查点。" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                    <Button Content="开始检测" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="OnStartCheckClicked"/>
                </Grid>

                <Grid Grid.Row="1" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardBorder}" Padding="18,14" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="9" FontSize="30" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="检测模块" FontSize="17" FontWeight="SemiBold"/>
                            <TextBlock Text="覆盖九项审查要求" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="18,14" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="1" FontSize="30" FontWeight="Bold" Foreground="#027A48"/>
                            <TextBlock Text="报告入口" FontSize="17" FontWeight="SemiBold"/>
                            <TextBlock Text="可选择本地可研文件" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="18,14">
                        <StackPanel>
                            <TextBlock Text="0" FontSize="30" FontWeight="Bold" Foreground="#B54708"/>
                            <TextBlock Text="后端任务" FontSize="17" FontWeight="SemiBold"/>
                            <TextBlock Text="待接入 AI 检测逻辑" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="18,16" Margin="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="4*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="报告文件" FontSize="17" FontWeight="SemiBold"/>
                            <TextBlock Text="支持 Word、PDF、Excel 等文件入口，具体解析后续由后端实现。"
                                       Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#F8FAFC" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="8" Padding="12" Margin="18,0">
                            <TextBlock x:Name="ReportPathTextBlock" Text="尚未选择可研报告" Foreground="#344054" TextTrimming="CharacterEllipsis"/>
                        </Border>
                        <Button Grid.Column="2" Content="选择文件" Style="{StaticResource PrimaryButton}" Click="OnChooseFileClicked"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="3" Margin="0,18,0,10">
                    <TextBlock Text="检测范围" FontSize="18" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="全选" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="OnSelectAllClicked"/>
                        <Button Content="清空" Style="{StaticResource SecondaryButton}" Click="OnClearAllClicked"/>
                    </StackPanel>
                </Grid>

                <UniformGrid x:Name="CheckItemsGrid" Grid.Row="4" Columns="3" Rows="3"/>

                <Grid Grid.Row="5" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="任务状态" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Border Grid.Column="1" Background="#F8FAFC" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="12">
                        <TextBlock x:Name="StatusTextBlock" Text="等待上传报告并选择检测项" Foreground="#475467"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
